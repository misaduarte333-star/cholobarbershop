# ============================================================================
# BarberCloud AI - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI Configuration (for n8n integration)
OPENAI_API_KEY=sk-your-openai-key-here

# WhatsApp Business API (for n8n integration)
WHATSAPP_API_TOKEN=EAAxxxx...
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# n8n Webhook URL
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/barbercloud

# Optional: Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
